{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.43.8.12551",
      "templateHash": "17467744873889228895"
    },
    "description": "Infraestructura del Sistema AAA: App Service (.NET 8) + Azure SQL"
  },
  "parameters": {
    "projectName": {
      "type": "string",
      "minLength": 2,
      "maxLength": 12,
      "metadata": {
        "description": "Nombre corto del proyecto. Prefijo de todos los recursos."
      }
    },
    "environment": {
      "type": "string",
      "defaultValue": "dev",
      "allowedValues": [
        "dev",
        "staging",
        "prod"
      ],
      "metadata": {
        "description": "Entorno de despliegue."
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Región de Azure. Por defecto, la del Resource Group."
      }
    },
    "sqlAdminLogin": {
      "type": "string",
      "defaultValue": "sqladmin",
      "minLength": 1,
      "maxLength": 128,
      "metadata": {
        "description": "Login administrador del SQL Server."
      }
    },
    "sqlAdminPassword": {
      "type": "securestring",
      "minLength": 12,
      "metadata": {
        "description": "  Contraseña del administrador SQL.\n@secure() → ARM la ofusca en logs de despliegue e historial de actividad.\nPasa el valor mediante --parameters o un archivo .bicepparam; nunca la\nescribas directamente en el comando de despliegue en texto plano.\n"
      }
    },
    "jwtSecretKey": {
      "type": "securestring",
      "minLength": 32,
      "metadata": {
        "description": "  Clave secreta para firmar los JWT (HMAC-SHA256). Mínimo 32 caracteres.\n@secure() → ARM la ofusca en logs. Para producción, reemplaza este\nparámetro por una referencia a Azure Key Vault en el appSetting:\n  '@Microsoft.KeyVault(VaultName=<kv>;SecretName=JwtSecretKey)'\n"
      }
    },
    "runSeedOnStartup": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Activa el seed de datos al arrancar la aplicación."
      }
    },
    "seedAdminEmail": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Email del usuario administrador inicial (solo cuando runSeedOnStartup=true)."
      }
    },
    "seedAdminPassword": {
      "type": "securestring",
      "defaultValue": "",
      "metadata": {
        "description": "Contraseña del usuario administrador inicial."
      }
    }
  },
  "variables": {
    "uniqueSuffix": "[take(uniqueString(resourceGroup().id), 6)]",
    "nameSuffix": "[toLower(format('{0}-{1}', parameters('projectName'), parameters('environment')))]",
    "uniqueNameSuffix": "[format('{0}-{1}', variables('nameSuffix'), variables('uniqueSuffix'))]",
    "appServicePlanName": "[format('plan-{0}', variables('nameSuffix'))]",
    "webAppName": "[format('app-{0}', variables('uniqueNameSuffix'))]",
    "sqlServerName": "[format('sql-{0}', variables('uniqueNameSuffix'))]",
    "sqlDatabaseName": "[format('sqldb-{0}', variables('nameSuffix'))]",
    "appServicePlanSku": "[if(equals(parameters('environment'), 'prod'), createObject('name', 'B2', 'tier', 'Basic', 'capacity', 1), createObject('name', 'B1', 'tier', 'Basic', 'capacity', 1))]",
    "aspNetCoreEnv": "[if(equals(parameters('environment'), 'prod'), 'Production', if(equals(parameters('environment'), 'staging'), 'Staging', 'Development'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Sql/servers",
      "apiVersion": "2023-05-01-preview",
      "name": "[variables('sqlServerName')]",
      "location": "[parameters('location')]",
      "properties": {
        "administratorLogin": "[parameters('sqlAdminLogin')]",
        "administratorLoginPassword": "[parameters('sqlAdminPassword')]",
        "minimalTlsVersion": "1.2",
        "publicNetworkAccess": "Enabled"
      }
    },
    {
      "type": "Microsoft.Sql/servers/firewallRules",
      "apiVersion": "2023-05-01-preview",
      "name": "[format('{0}/{1}', variables('sqlServerName'), 'AllowAllAzureServices')]",
      "properties": {
        "startIpAddress": "0.0.0.0",
        "endIpAddress": "0.0.0.0"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ]
    },
    {
      "type": "Microsoft.Sql/servers/databases",
      "apiVersion": "2023-05-01-preview",
      "name": "[format('{0}/{1}', variables('sqlServerName'), variables('sqlDatabaseName'))]",
      "location": "[parameters('location')]",
      "sku": {
        "name": "Basic",
        "tier": "Basic",
        "capacity": 5
      },
      "properties": {
        "collation": "SQL_Latin1_General_CP1_CI_AS",
        "maxSizeBytes": 2147483648
      },
      "dependsOn": [
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('appServicePlanName')]",
      "location": "[parameters('location')]",
      "kind": "linux",
      "sku": "[variables('appServicePlanSku')]",
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('webAppName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux",
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "DOTNETCORE|8.0",
          "minTlsVersion": "1.2",
          "http20Enabled": true,
          "ftpsState": "Disabled",
          "connectionStrings": [
            {
              "name": "DefaultConnection",
              "connectionString": "[join(createArray(format('Server=tcp:{0},1433', reference(resourceId('Microsoft.Sql/servers', variables('sqlServerName')), '2023-05-01-preview').fullyQualifiedDomainName), format('Initial Catalog={0}', variables('sqlDatabaseName')), 'Persist Security Info=False', format('User ID={0}', parameters('sqlAdminLogin')), format('Password={0}', parameters('sqlAdminPassword')), 'MultipleActiveResultSets=False', 'Encrypt=True', 'TrustServerCertificate=False', 'Connection Timeout=30'), ';')]",
              "type": "SQLAzure"
            }
          ],
          "appSettings": [
            {
              "name": "ASPNETCORE_ENVIRONMENT",
              "value": "[variables('aspNetCoreEnv')]"
            },
            {
              "name": "WEBSITE_RUN_FROM_PACKAGE",
              "value": "1"
            },
            {
              "name": "Jwt__SecretKey",
              "value": "[parameters('jwtSecretKey')]"
            },
            {
              "name": "Jwt__Issuer",
              "value": "SistemaAAA"
            },
            {
              "name": "Jwt__Audience",
              "value": "SistemaAAA-clients"
            },
            {
              "name": "Jwt__ExpiresMinutes",
              "value": "60"
            },
            {
              "name": "Seed__RunOnStartup",
              "value": "[string(parameters('runSeedOnStartup'))]"
            },
            {
              "name": "Seed__AdminEmail",
              "value": "[parameters('seedAdminEmail')]"
            },
            {
              "name": "Seed__AdminPassword",
              "value": "[parameters('seedAdminPassword')]"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('appServicePlanName'))]",
        "[resourceId('Microsoft.Sql/servers', variables('sqlServerName'))]"
      ]
    }
  ],
  "outputs": {
    "webAppUrl": {
      "type": "string",
      "metadata": {
        "description": "URL pública de la Web App."
      },
      "value": "[format('https://{0}', reference(resourceId('Microsoft.Web/sites', variables('webAppName')), '2023-12-01').defaultHostName)]"
    },
    "webAppName": {
      "type": "string",
      "metadata": {
        "description": "Nombre del recurso Web App (requerido por el paso \"Azure Web App Deploy\" del pipeline CI/CD)."
      },
      "value": "[variables('webAppName')]"
    },
    "appServicePlanName": {
      "type": "string",
      "metadata": {
        "description": "Nombre del recurso App Service Plan."
      },
      "value": "[variables('appServicePlanName')]"
    },
    "sqlServerFqdn": {
      "type": "string",
      "metadata": {
        "description": "FQDN del servidor SQL (para configurar reglas de firewall adicionales o acceso desde herramientas locales)."
      },
      "value": "[reference(resourceId('Microsoft.Sql/servers', variables('sqlServerName')), '2023-05-01-preview').fullyQualifiedDomainName]"
    },
    "sqlDatabaseName": {
      "type": "string",
      "metadata": {
        "description": "Nombre de la base de datos SQL."
      },
      "value": "[variables('sqlDatabaseName')]"
    }
  }
}